<?xml version="1.0" encoding="utf-8"?>
<!--
  Lock screen widget layout.
  Kept intentionally minimal — just a single tap-to-log button
  that works directly from the lock screen.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lockscreen_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/lockscreen_widget_bg"
    android:gravity="center"
    android:padding="14dp">

    <!-- Branding row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp"
        android:alpha="0.75">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚬"
            android:textSize="13sp"
            android:layout_marginEnd="5dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMOKE TRACKER"
            android:textColor="#ffffff"
            android:textSize="9sp"
            android:letterSpacing="0.2"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Big log button -->
    <LinearLayout
        android:id="@+id/lockscreen_log_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/lockscreen_button_bg"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:clickable="true"
        android:focusable="true"
        android:gap="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:textColor="#ffffff"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log Cigarette"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />
    </LinearLayout>

    <!-- Today count — small, below button -->
    <TextView
        android:id="@+id/lockscreen_count_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 today"
        android:textColor="#ffffff"
        android:textSize="11sp"
        android:alpha="0.55"
        android:layout_marginTop="10dp" />

</LinearLayout>
