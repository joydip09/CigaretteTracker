<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp"
    android:gravity="center">

    <!-- Top row: icon + title + cost -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚬"
            android:textSize="14sp"
            android:layout_marginEnd="6dp" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SMOKE TRACKER"
            android:textColor="#8a6a5a"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_cost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="৳0"
            android:textColor="#ff6b35"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Counter area -->
    <LinearLayout
        android:id="@+id/widget_counter_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/widget_counter_bg"
        android:layout_marginBottom="10dp">
        <TextView
            android:id="@+id/widget_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#fff5ef"
            android:textSize="48sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="0.9" />
        <TextView
            android:id="@+id/widget_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="cigarettes today"
            android:textColor="#ff6b35"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <!-- Bottom row: Log + Undo side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_add_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.65"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/widget_button_bg"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:layout_margin="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Undo button: active state (green timer) -->
        <FrameLayout
            android:id="@+id/widget_undo_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.35"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:id="@+id/widget_undo_active_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_undo_bg_active"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↩"
                    android:textColor="#34c759"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_undo_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3:00"
                    android:textColor="#34c759"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Expired state (lock icon) -->
            <LinearLayout
                android:id="@+id/widget_undo_expired_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_undo_bg_expired"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="14sp" />
            </LinearLayout>

        </FrameLayout>
    </LinearLayout>

</LinearLayout>
